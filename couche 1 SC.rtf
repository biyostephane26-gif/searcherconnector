const SERPER_KEY = import.meta.env.VITE_SERPER_API_KEY\par
\par
async function search(query: string) \{\par
  try \{\par
    const res = await fetch('https://google.serper.dev/search', \{\par
      method: 'POST',\par
      headers: \{ 'X-API-KEY': SERPER_KEY, 'Content-Type': 'application/json' \},\par
      body: JSON.stringify(\{ q: query, num: 10, gl: 'us', hl: 'en' \}),\par
    \})\par
    const data = await res.json()\par
    return data.organic || []\par
  \} catch \{\par
    return []\par
  \}\par
\}\par
\par
export async function searchJobs(domain: string, country: string) \{\par
  const queries = [\par
    `$\{domain\} job hiring $\{country\} 2026 site:linkedin.com OR site:indeed.com`,\par
    `$\{domain\} remote job worldwide 2026`,\par
    `hiring $\{domain\} expert freelance contract 2026`,\par
    `$\{domain\} position open apply now`,\par
    `$\{domain\} job opportunity site:glassdoor.com OR site:remoteok.com`,\par
  ]\par
  const results = await Promise.all(queries.slice(0, 3).map(q => search(q)))\par
  return results.flat()\par
\}\par
\par
export async function searchSalaries(role: string, country: string) \{\par
  const results = await search(`average salary $\{role\} $\{country\} 2026 USD`)\par
  return results\par
\}\par
\par
export async function searchInvestors(sector: string, ticketSize: string) \{\par
  const results = await Promise.all([\par
    search(`venture capital investors $\{sector\} 2026 crunchbase`),\par
    search(`angel investors $\{sector\} funding $\{ticketSize\}`),\par
    search(`VC fund $\{sector\} portfolio investments`),\par
  ])\par
  return results.flat()\par
\}\par
\par
export async function searchClients(product: string, targetCustomer: string, country: string) \{\par
  const results = await search(\par
    `people looking for $\{product\} $\{targetCustomer\} $\{country\} buy`\par
  )\par
  return results\par
\}\par
