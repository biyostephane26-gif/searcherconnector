export async function analyseProfile(data: \{\par
  fullName: string\par
  domain: string\par
  profileType: string\par
  documents: string[]\par
  portfolioUrl?: string\par
  githubUrl?: string\par
  youtubeUrl?: string\par
  bio?: string\par
\}) \{\par
  const model = genAI.getGenerativeModel(\{ model: 'gemini-1.5-flash' \})\par
  const prompt = `You are Searcher Connector's verification AI.\par
Analyse this professional profile and decide access level.\par
\par
Name: $\{data.fullName\}\par
Domain: $\{data.domain\}\par
Type: $\{data.profileType\}\par
Documents: $\{data.documents.join(', ')\}\par
Portfolio: $\{data.portfolioUrl || 'none'\}\par
GitHub: $\{data.githubUrl || 'none'\}\par
YouTube: $\{data.youtubeUrl || 'none'\}\par
Bio: $\{data.bio || 'none'\}\par
\par
Rules:\par
- GENIUS: truly exceptional world-class proof only\par
- VERIFIED: any real proof of competence\par
- REFUSED: insufficient or dishonest proof\par
\par
Respond ONLY in JSON, no markdown:\par
\{"status":"verified","reason":"one sentence","strengths":["s1"],"improvements":["i1"]\}`\par
\par
  try \{\par
    const result = await model.generateContent(prompt)\par
    const text = result.response.text().replace(/```json|```/g, '').trim()\par
    return JSON.parse(text)\par
  \} catch \{\par
    return \{ status: 'pending', reason: 'Analysis in progress', strengths: [], improvements: [] \}\par
  \}\par
\}\par
