=================================================================\par
\'c9TAPE 3 \f1\emdash  SUPABASE SCHEMA COMPLET\par
=================================================================\par
\par
Cr\f0\'e9e le fichier src/lib/schema.sql avec ce contenu exact.\par
Ce SQL doit \'eatre ex\'e9cut\'e9 dans Supabase SQL Editor.\par
\par
-- Extension UUID\par
create extension if not exists "uuid-ossp";\par
\par
-- Table principale des profils\par
create table if not exists users_profiles (\par
  id uuid references auth.users primary key,\par
  full_name text not null,\par
  email text not null,\par
  profile_type text not null check (\par
    profile_type in ('job_seeker','freelance','business','investor')\par
  ),\par
  domain text,\par
  country text,\par
  city text,\par
  languages text[],\par
  salary_min integer default 0,\par
  salary_max integer default 0,\par
  currency text default 'USD',\par
  bio text,\par
  avatar_url text,\par
  cv_url text,\par
  portfolio_url text,\par
  github_url text,\par
  behance_url text,\par
  youtube_url text,\par
  linkedin_url text,\par
  tiktok_url text,\par
  website_url text,\par
  verification_status text default 'pending' check (\par
    verification_status in ('pending','verified','genius','refused')\par
  ),\par
  refusal_reason text,\par
  plan text default 'free' check (\par
    plan in ('free','talent','business','investor')\par
  ),\par
  role text default 'user' check (role in ('user','admin','founder')),\par
  stripe_customer_id text,\par
  stripe_subscription_id text,\par
  plan_expires_at timestamp,\par
  free_mode boolean default true,\par
  response_template text,\par
  surveillance_active boolean default false,\par
  salary_alert_threshold integer default 10,\par
  search_preferences jsonb default '\{\}',\par
  profile_completion integer default 0,\par
  referral_code text unique default substr(md5(random()::text), 1, 8),\par
  referred_by uuid references users_profiles(id),\par
  created_at timestamp default now(),\par
  updated_at timestamp default now()\par
);\par
\par
-- Documents upload\'e9s\par
create table if not exists uploaded_documents (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  doc_type text not null,\par
  file_url text not null,\par
  file_name text,\par
  created_at timestamp default now()\par
);\par
\par
-- Opportunit\'e9s trouv\'e9es par Searcher\par
create table if not exists opportunities (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  title text not null,\par
  company text,\par
  location text,\par
  country text,\par
  salary_min integer default 0,\par
  salary_max integer default 0,\par
  currency text default 'USD',\par
  published_at timestamp,\par
  hours_ago integer default 0,\par
  applicants_count integer default 0,\par
  score integer default 0,\par
  match_reason text,\par
  source_platform text,\par
  original_url text,\par
  is_foreign boolean default false,\par
  is_suspicious boolean default false,\par
  visa_required boolean default false,\par
  passport_required boolean default false,\par
  status text default 'found' check (\par
    status in ('found','auto_applied','pending_action','response_received','dismissed')\par
  ),\par
  application_message text,\par
  alert_count integer default 0,\par
  last_alerted_at timestamp,\par
  created_at timestamp default now()\par
);\par
\par
-- Candidatures envoy\'e9es\par
create table if not exists applications_sent (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  opportunity_id uuid references opportunities(id) on delete cascade,\par
  company text,\par
  job_title text,\par
  cover_message text,\par
  cv_adapted text,\par
  visual_project_url text,\par
  applied_at timestamp default now(),\par
  response_received boolean default false,\par
  response_content text,\par
  response_draft text,\par
  response_status text default 'waiting'\par
);\par
\par
-- Notifications\par
create table if not exists notifications (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  type text not null,\par
  title text,\par
  message text not null,\par
  financial_value text,\par
  action_url text,\par
  action_label text,\par
  is_read boolean default false,\par
  requires_action boolean default false,\par
  dismissed boolean default false,\par
  alert_count integer default 0,\par
  created_at timestamp default now()\par
);\par
\par
-- R\'e9seau social : connexions\par
create table if not exists connections (\par
  id uuid primary key default gen_random_uuid(),\par
  from_user_id uuid references users_profiles(id) on delete cascade,\par
  to_user_id uuid references users_profiles(id) on delete cascade,\par
  status text default 'pending' check (status in ('pending','accepted','declined')),\par
  created_at timestamp default now(),\par
  unique(from_user_id, to_user_id)\par
);\par
\par
-- R\'e9seau social : publications\par
create table if not exists posts (\par
  id uuid primary key default gen_random_uuid(),\par
  author_id uuid references users_profiles(id) on delete cascade,\par
  content text not null,\par
  image_url text,\par
  post_type text default 'general' check (\par
    post_type in ('general','article','opportunity_share','achievement','insight')\par
  ),\par
  likes_count integer default 0,\par
  comments_count integer default 0,\par
  shares_count integer default 0,\par
  is_genius_post boolean default false,\par
  created_at timestamp default now(),\par
  updated_at timestamp default now()\par
);\par
\par
-- Likes sur les posts\par
create table if not exists post_likes (\par
  id uuid primary key default gen_random_uuid(),\par
  post_id uuid references posts(id) on delete cascade,\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  created_at timestamp default now(),\par
  unique(post_id, user_id)\par
);\par
\par
-- Commentaires\par
create table if not exists post_comments (\par
  id uuid primary key default gen_random_uuid(),\par
  post_id uuid references posts(id) on delete cascade,\par
  author_id uuid references users_profiles(id) on delete cascade,\par
  content text not null,\par
  created_at timestamp default now()\par
);\par
\par
-- Messagerie directe\par
create table if not exists messages (\par
  id uuid primary key default gen_random_uuid(),\par
  from_user_id uuid references users_profiles(id) on delete cascade,\par
  to_user_id uuid references users_profiles(id) on delete cascade,\par
  content text not null,\par
  is_read boolean default false,\par
  searcher_draft boolean default false,\par
  created_at timestamp default now()\par
);\par
\par
-- Recommandations v\'e9rifi\'e9es\par
create table if not exists recommendations (\par
  id uuid primary key default gen_random_uuid(),\par
  from_user_id uuid references users_profiles(id) on delete cascade,\par
  to_user_id uuid references users_profiles(id) on delete cascade,\par
  message text not null,\par
  is_verified boolean default true,\par
  gemini_authenticity_score integer default 0,\par
  created_at timestamp default now()\par
);\par
\par
-- Comparateur salaires (cache)\par
create table if not exists salary_data (\par
  id uuid primary key default gen_random_uuid(),\par
  role text not null,\par
  country text not null,\par
  salary_min integer,\par
  salary_median integer,\par
  salary_max integer,\par
  growth_percent numeric,\par
  currency text default 'USD',\par
  fetched_at timestamp default now()\par
);\par
\par
-- Recherches sauvegard\'e9es\par
create table if not exists saved_searches (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  query text,\par
  domain text,\par
  country text,\par
  salary_min integer,\par
  salary_max integer,\par
  auto_repeat boolean default false,\par
  repeat_frequency text default 'daily',\par
  last_run_at timestamp,\par
  created_at timestamp default now()\par
);\par
\par
-- Abonnements Stripe\par
create table if not exists subscriptions (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  stripe_subscription_id text unique,\par
  plan text,\par
  status text,\par
  current_period_end timestamp,\par
  created_at timestamp default now()\par
);\par
\par
-- Parrainage\par
create table if not exists referrals (\par
  id uuid primary key default gen_random_uuid(),\par
  referrer_id uuid references users_profiles(id) on delete cascade,\par
  referred_id uuid references users_profiles(id) on delete cascade,\par
  reward_applied boolean default false,\par
  created_at timestamp default now()\par
);\par
\par
-- Param\'e8tres app (FREE_MODE, etc.)\par
create table if not exists app_settings (\par
  key text primary key,\par
  value text,\par
  updated_at timestamp default now()\par
);\par
insert into app_settings (key, value) values ('FREE_MODE', 'true') on conflict do nothing;\par
\par
-- Entretiens planifi\'e9s\par
create table if not exists interviews (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  company text,\par
  job_title text,\par
  interview_at timestamp,\par
  timezone text,\par
  format text check (format in ('video','phone','in_person')),\par
  meeting_url text,\par
  notes text,\par
  preparation_done boolean default false,\par
  status text default 'scheduled' check (\par
    status in ('scheduled','completed','cancelled')\par
  ),\par
  created_at timestamp default now()\par
);\par
\par
-- Log des actions de Searcher\par
create table if not exists searcher_logs (\par
  id uuid primary key default gen_random_uuid(),\par
  user_id uuid references users_profiles(id) on delete cascade,\par
  action_type text not null,\par
  description text not null,\par
  platform text,\par
  result text,\par
  auto_promo_sent boolean default false,\par
  created_at timestamp default now()\par
);\par
\par
-- RLS : activer sur toutes les tables\par
alter table users_profiles enable row level security;\par
alter table uploaded_documents enable row level security;\par
alter table opportunities enable row level security;\par
alter table applications_sent enable row level security;\par
alter table notifications enable row level security;\par
alter table connections enable row level security;\par
alter table posts enable row level security;\par
alter table post_likes enable row level security;\par
alter table post_comments enable row level security;\par
alter table messages enable row level security;\par
alter table recommendations enable row level security;\par
alter table salary_data enable row level security;\par
alter table saved_searches enable row level security;\par
alter table subscriptions enable row level security;\par
alter table referrals enable row level security;\par
alter table interviews enable row level security;\par
alter table searcher_logs enable row level security;\par
\par
-- Policies users_profiles\par
create policy "insert_own_profile" on users_profiles\par
  for insert with check (auth.uid() = id);\par
create policy "select_own_profile" on users_profiles\par
  for select using (auth.uid() = id);\par
create policy "update_own_profile" on users_profiles\par
  for update using (auth.uid() = id);\par
create policy "select_verified_profiles" on users_profiles\par
  for select using (verification_status in ('verified','genius'));\par
\par
-- Policies documents\par
create policy "insert_own_docs" on uploaded_documents\par
  for insert with check (auth.uid() = user_id);\par
create policy "select_own_docs" on uploaded_documents\par
  for select using (auth.uid() = user_id);\par
\par
-- Policies opportunities\par
create policy "manage_own_opps" on opportunities\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies applications\par
create policy "manage_own_apps" on applications_sent\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies notifications\par
create policy "manage_own_notifs" on notifications\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies connections\par
create policy "manage_own_connections" on connections\par
  for all using (auth.uid() = from_user_id or auth.uid() = to_user_id);\par
\par
-- Policies posts (tous les v\'e9rifi\'e9s peuvent lire)\par
create policy "insert_own_posts" on posts\par
  for insert with check (auth.uid() = author_id);\par
create policy "select_all_posts" on posts\par
  for select using (true);\par
create policy "update_own_posts" on posts\par
  for update using (auth.uid() = author_id);\par
create policy "delete_own_posts" on posts\par
  for delete using (auth.uid() = author_id);\par
\par
-- Policies likes\par
create policy "manage_likes" on post_likes\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies commentaires\par
create policy "manage_comments" on post_comments\par
  for all using (auth.uid() = author_id);\par
create policy "read_comments" on post_comments\par
  for select using (true);\par
\par
-- Policies messages\par
create policy "manage_messages" on messages\par
  for all using (\par
    auth.uid() = from_user_id or auth.uid() = to_user_id\par
  );\par
\par
-- Policies recommandations\par
create policy "manage_recs" on recommendations\par
  for all using (\par
    auth.uid() = from_user_id or auth.uid() = to_user_id\par
  );\par
create policy "read_recs" on recommendations\par
  for select using (true);\par
\par
-- Policies salary\par
create policy "read_salary" on salary_data\par
  for select using (true);\par
create policy "insert_salary" on salary_data\par
  for insert with check (true);\par
\par
-- Policies saved searches\par
create policy "manage_saved_searches" on saved_searches\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies subscriptions\par
create policy "manage_own_subs" on subscriptions\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies referrals\par
create policy "manage_referrals" on referrals\par
  for all using (\par
    auth.uid() = referrer_id or auth.uid() = referred_id\par
  );\par
\par
-- Policies interviews\par
create policy "manage_interviews" on interviews\par
  for all using (auth.uid() = user_id);\par
\par
-- Policies logs\par
create policy "manage_logs" on searcher_logs\par
  for all using (auth.uid() = user_id);\par
\par
-- App settings lisibles par tous\par
create policy "read_settings" on app_settings\par
  for select using (true);\par
\par
